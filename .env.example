# ─────────────────────────────────────────────
#  AlRajhi Bank | Transactions — Backend Config
# ─────────────────────────────────────────────

# ── Server ────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── PostgreSQL ────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=alrajhi_transactions
DB_USER=postgres
DB_PASSWORD=your_postgres_password
# Optional: full connection string (overrides individual fields above)
# DATABASE_URL=postgresql://postgres:your_postgres_password@localhost:5432/alrajhi_transactions

# ── JWT Tokens ────────────────────────────────
# Generate strong secrets:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_byte_hex_secret_access
JWT_REFRESH_SECRET=replace_with_64_byte_hex_secret_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── AES-256-GCM Encryption ────────────────────
# Must be exactly 32 bytes (64 hex chars)
# Generate:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_32_byte_hex_key_for_aes256gcm

# ── CORS ──────────────────────────────────────
ALLOWED_ORIGIN=http://localhost:55484

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=20
